# Copy to .env and fill in. All values are optional for a fake-LLM local run.

# --- LLM ---------------------------------------------------------------
# provider: fake (offline, default) | openai | anthropic | groq | openrouter
LLM_PROVIDER=fake
LLM_API_KEY=
# Examples:
#   groq:       llama-3.1-8b-instant
#   openrouter: meta-llama/llama-3.1-8b-instruct:free
#   openai:     gpt-4o-mini
#   anthropic:  claude-haiku-3-5-20251001
DEFAULT_MODEL=fake

# --- Telegram channel --------------------------------------------------
# Create a bot with @BotFather and paste the token here to enable the channel.
TELEGRAM_BOT_TOKEN=
# Optional: id of the workflow inbound Telegram messages should drive.
# If empty, a default single "Concierge" agent answers.
CHANNEL_WORKFLOW_ID=

# --- Infra (defaults match docker-compose) -----------------------------
# Local dev without Docker uses SQLite + the in-memory bus automatically.
# DATABASE_URL=sqlite:///./helmsman.db
# BUS_BACKEND=memory
