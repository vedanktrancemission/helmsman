# Copy to .env and fill in. All values are optional for a fake-LLM local run.

# --- LLM ---------------------------------------------------------------
# Provider is now auto-detected from model name — just set the keys you need.
# LLM_PROVIDER is used as fallback if model name doesn't match any known pattern.
LLM_PROVIDER=fake
DEFAULT_MODEL=fake

# Per-provider API keys — set whichever providers you want to use.
# The correct key is picked automatically based on the model name.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Legacy fallback key (used if per-provider key above is not set)
LLM_API_KEY=

# Model name → provider auto-detection:
#   gemini-*              → Gemini   (aistudio.google.com)
#   mistral-*, open-mistral-*  → Mistral  (console.mistral.ai)
#   gpt-*, o1-*, o3-*    → OpenAI   (platform.openai.com)
#   claude-*              → Anthropic (console.anthropic.com)
#   llama*, mixtral*      → Groq     (console.groq.com)
#   anything with /       → OpenRouter (openrouter.ai)

# --- Telegram channel --------------------------------------------------
# Create a bot with @BotFather and paste the token here to enable the channel.
TELEGRAM_BOT_TOKEN=
# Optional: id of the workflow inbound Telegram messages should drive.
# If empty, a default single "Concierge" agent answers.
CHANNEL_WORKFLOW_ID=

# --- Infra (defaults match docker-compose) -----------------------------
# Local dev without Docker uses SQLite + the in-memory bus automatically.
# DATABASE_URL=sqlite:///./helmsman.db
# BUS_BACKEND=memory
